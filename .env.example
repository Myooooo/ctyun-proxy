# CTYun Coding Plan Proxy Configuration

# Your CTYun Coding Plan APP Key (cp_xxx)
CTYUN_APP_KEY=cp_xxxxxxxxxxxx

# Upstream base URL (default: https://wishub-x6.ctyun.cn/coding)
CTYUN_BASE_URL=https://wishub-x6.ctyun.cn/coding

# Max retries for chat completions (default: 5)
MAX_RETRIES=5

# Default model for chat completions (default: GLM-5.1)
DEFAULT_MODEL=GLM-5.1

# Request timeout in seconds (default: 300)
REQUEST_TIMEOUT=600
STREAM_FIRST_CHUNK_TIMEOUT=60

# Server port (default: 8080)
PORT=8080
