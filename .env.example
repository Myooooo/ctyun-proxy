# CTYun Coding Plan Proxy Configuration

# Upstream base URL (default: https://wishub-x6.ctyun.cn/coding)
# For other OpenAI-compatible platforms, e.g.:
#   DeepSeek:    https://api.deepseek.com
#   Moonshot:    https://api.moonshot.cn
#   Zhipu:       https://open.bigmodel.cn/api/paas
CTYUN_BASE_URL=https://wishub-x6.ctyun.cn/coding

# API Key for upstream (if set, overrides the Authorization header)
# Leave empty to pass through the original request's auth header
API_KEY=

# Default model for chat completions (default: GLM-5.1)
# Set to empty to keep the model from the original request
DEFAULT_MODEL=GLM-5.1

# Max retries for chat completions (default: 5)
MAX_RETRIES=5

# Request timeout in seconds (default: 600)
REQUEST_TIMEOUT=600
STREAM_FIRST_CHUNK_TIMEOUT=60

# Server port (default: 8080)
PORT=8080
